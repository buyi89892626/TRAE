page {
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 32rpx;
  color: #333333;
  min-height: 100vh;
}

.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.text-large {
  font-size: 36rpx;
}

.text-xlarge {
  font-size: 40rpx;
}

.text-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #C44569;
}

.text-subtitle {
  font-size: 32rpx;
  color: #666666;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: linear-gradient(135deg, #F8B500 0%, #FF8C00 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(248, 181, 0, 0.4);
}

.btn-secondary::after {
  border: none;
}

.btn-outline {
  background: white;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
  border-radius: 50rpx;
  font-size: 32rpx;
}

.btn-outline::after {
  border: none;
}

.card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #C44569;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.card-title-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 32rpx 0 20rpx 0;
  padding-left: 16rpx;
  border-left: 8rpx solid #FF6B9D;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-pink {
  background: #FFE4EC;
  color: #C44569;
}

.tag-yellow {
  background: #FFF4D6;
  color: #B8860B;
}

.tag-green {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-red {
  background: #FFEBEE;
  color: #C62828;
}

.tag-purple {
  background: #F3E5F5;
  color: #7B1FA2;
}

.divider {
  height: 1rpx;
  background: #FFE4EC;
  margin: 24rpx 0;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  justify-content: space-between;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mt-20 { margin-top: 20rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-32 { margin-bottom: 32rpx; }
.p-24 { padding: 24rpx; }

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.loading-text {
  color: #FF6B9D;
  font-size: 32rpx;
  text-align: center;
  padding: 40rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
