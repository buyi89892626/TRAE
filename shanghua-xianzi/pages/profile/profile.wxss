.profile-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  padding-bottom: 40rpx;
}

/* 顶部用户区 */
.profile-header {
  position: relative;
  overflow: hidden;
  padding-bottom: 32rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 50%, #F8B500 100%);
  border-radius: 0 0 60rpx 60rpx;
  opacity: 0.9;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 32rpx 0;
}

.user-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.user-badge {
  background: linear-gradient(135deg, #F8B500 0%, #FFD700 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.user-badge text {
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.login-btn {
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10px);
  color: white;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 30rpx;
  font-size: 28rpx;
  height: 64rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
}

.login-btn::after {
  border: none;
}

/* 统计行 */
.stats-row {
  display: flex;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.15);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #C44569;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #FFE4EC;
  align-self: center;
}

/* VIP卡片 */
.vip-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(26, 26, 46, 0.3);
}

.vip-left {
  display: flex;
  align-items: center;
}

.vip-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.vip-info {
  display: flex;
  flex-direction: column;
}

.vip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFD700;
  margin-bottom: 4rpx;
}

.vip-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.vip-btn {
  background: linear-gradient(135deg, #F8B500 0%, #FFD700 100%);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

.vip-btn text {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: bold;
}

/* 设置区 */
.settings-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin: 0 32rpx 16rpx;
}

.settings-card {
  background: white;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.06);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #FFF0F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.setting-name {
  font-size: 30rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* 字体选择弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.font-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.font-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFF9FB;
  border: 2rpx solid #FFE4EC;
  border-radius: 16rpx;
  position: relative;
}

.font-option.active {
  border-color: #FF6B9D;
  background: #FFF0F5;
}

.font-preview {
  margin-right: 20rpx;
}

.font-preview.normal text {
  font-size: 26rpx;
  color: #666;
}

.font-preview.large text {
  font-size: 32rpx;
  color: #666;
}

.font-preview.xlarge text {
  font-size: 38rpx;
  color: #666;
}

.font-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background: #FF6B9D;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
}

.safe-bottom {
  height: 40rpx;
}
