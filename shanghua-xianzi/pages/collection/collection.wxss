.collection-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 50%, #F8B500 100%);
  border-radius: 0 0 60rpx 60rpx;
  opacity: 0.9;
}

.header-content {
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* Tab头部 */
.tab-header {
  display: flex;
  margin: -20rpx 24rpx 24rpx;
  background: white;
  border-radius: 24rpx;
  padding: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.15);
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
}

.tab-item.active text {
  color: white;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
}

.tab-count {
  font-size: 24rpx !important;
  margin-top: 4rpx;
  opacity: 0.8;
}

/* 搜索栏 */
.search-bar {
  padding: 0 24rpx 20rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.08);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 分类滚动 */
.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: white;
  border-radius: 20rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 157, 0.06);
}

.category-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
}

.category-item.active text {
  color: white;
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.category-item text {
  font-size: 26rpx;
  color: #666;
}

/* 列表内容 */
.list-content {
  padding: 0 24rpx;
}

.flower-list {
  display: flex;
  flex-direction: column;
}

.flower-card {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.06);
}

.card-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-right: 20rpx;
  position: relative;
  flex-shrink: 0;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-emoji {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFF4D6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.score-tag {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(0,0,0,0.6);
  color: white;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 16rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.card-alias {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.card-time {
  font-size: 22rpx;
  color: #BBB;
}

.card-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFF0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  display: inline-block;
}

.empty-btn::after {
  border: none;
}

/* 底部操作 */
.footer-action {
  text-align: center;
  margin-top: 40rpx;
  padding: 0 24rpx;
}

.clear-btn {
  background: white;
  color: #FF6B9D;
  border: 2rpx solid #FFE4EC;
  border-radius: 40rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 76rpx;
}

.clear-btn::after {
  border: none;
}

.safe-bottom {
  height: 40rpx;
}
