.community-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF0F5 100%);
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 50%, #F8B500 100%);
  border-radius: 0 0 60rpx 60rpx;
  opacity: 0.9;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.publish-btn {
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10px);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
}

.publish-btn text {
  font-size: 28rpx;
  color: white;
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

/* 热门话题 */
.topics-section {
  margin: -10rpx 24rpx 0;
  position: relative;
  z-index: 10;
}

.section-title {
  margin-bottom: 16rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.topics-scroll {
  white-space: nowrap;
}

.topics-list {
  display: inline-flex;
}

.topic-item {
  display: inline-flex;
  flex-direction: column;
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.1);
}

.topic-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #C44569;
  margin-bottom: 4rpx;
}

.topic-count {
  font-size: 22rpx;
  color: #999;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: white;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #999;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  color: white;
  font-weight: 500;
}

/* 帖子列表 */
.post-list {
  padding: 0 24rpx;
}

.post-card {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.06);
}

/* 帖子头部 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFE4EC 0%, #FFF4D6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 16rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.user-level {
  font-size: 22rpx;
  color: #F8B500;
  background: #FFF9E6;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.post-meta {
  display: flex;
  align-items: center;
}

.post-location, .post-time {
  font-size: 24rpx;
  color: #999;
}

.more-btn {
  font-size: 32rpx;
  color: #CCC;
  padding: 8rpx;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

/* 帖子图片 */
.post-images {
  margin-bottom: 16rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.image-count-1 .image-item {
  width: 100%;
  height: 400rpx;
}

.image-count-2 .image-item,
.image-count-4 .image-item {
  width: calc(50% - 4rpx);
  height: 280rpx;
}

.image-count-3 .image-item,
.image-count-5 .image-item,
.image-count-6 .image-item,
.image-count-7 .image-item,
.image-count-8 .image-item,
.image-count-9 .image-item {
  width: calc(33.33% - 6rpx);
  height: 200rpx;
}

.image-item {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFF4D6 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.image-emoji {
  font-size: 72rpx;
}

/* 花卉标签 */
.post-flower-tag {
  margin-bottom: 16rpx;
}

/* 操作栏 */
.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
  border-top: 1rpx solid #FFF0F5;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.action-item.liked .action-count {
  color: #FF6B9D;
}

.action-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-count {
  font-size: 26rpx;
  color: #999;
}

/* 悬浮发布按钮 */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.5);
  z-index: 100;
}

.fab-icon {
  font-size: 40rpx;
}

.safe-bottom {
  height: 40rpx;
}
