.camera-page {
  width: 100vw;
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
}

.camera-view {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 顶部操作栏 */
.camera-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 32rpx 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 100%);
  z-index: 10;
}

.top-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
}

.top-btn text {
  font-size: 36rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 500;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.placeholder {
  opacity: 0;
}

/* 取景框 */
.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.guide-box {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  border: 4rpx solid rgba(255, 107, 157, 0.6);
  border-radius: 24rpx;
  background: rgba(255, 107, 157, 0.05);
  transition: all 0.3s ease;
}

.guide-box.blurry {
  border-color: #FF5252;
  background: rgba(255, 82, 82, 0.1);
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

.guide-corner {
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  border-color: #FF6B9D;
  border-style: solid;
}

.guide-corner.tl {
  top: -4rpx;
  left: -4rpx;
  border-width: 8rpx 0 0 8rpx;
  border-top-left-radius: 16rpx;
}

.guide-corner.tr {
  top: -4rpx;
  right: -4rpx;
  border-width: 8rpx 8rpx 0 0;
  border-top-right-radius: 16rpx;
}

.guide-corner.bl {
  bottom: -4rpx;
  left: -4rpx;
  border-width: 0 0 8rpx 8rpx;
  border-bottom-left-radius: 16rpx;
}

.guide-corner.br {
  bottom: -4rpx;
  right: -4rpx;
  border-width: 0 8rpx 8rpx 0;
  border-bottom-right-radius: 16rpx;
}

.guide-line-1 {
  position: absolute;
  top: 50%;
  left: 20%;
  right: 20%;
  height: 1rpx;
  background: rgba(255, 107, 157, 0.3);
  transform: translateY(-50%);
}

.guide-line-2 {
  position: absolute;
  left: 50%;
  top: 20%;
  bottom: 20%;
  width: 1rpx;
  background: rgba(255, 107, 157, 0.3);
  transform: translateX(-50%);
}

.guide-tip {
  margin-top: 40rpx;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}

.guide-tip text {
  color: white;
  font-size: 28rpx;
}

/* 底部操作栏 */
.camera-bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 40rpx 60rpx 80rpx;
  background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, transparent 100%);
  z-index: 10;
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.btn-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 24rpx;
  color: white;
}

.shutter-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.shutter-outer {
  width: 140rpx;
  height: 140rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.shutter-inner {
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.5);
  transition: all 0.2s ease;
}

.shutter-inner.shooting {
  transform: scale(0.9);
  background: #C44569;
}

.shutter-tip {
  font-size: 24rpx;
  color: white;
}

/* 预览页面 */
.preview-page {
  width: 100vw;
  height: 100vh;
  background: #000;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 32rpx 20rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 100%);
  z-index: 10;
}

.preview-tip {
  position: absolute;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
}

.preview-tip text {
  color: white;
  font-size: 30rpx;
}

.preview-bottom-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 40rpx 40rpx 80rpx;
  background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, transparent 100%);
  z-index: 10;
}

.preview-btn {
  width: 280rpx;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-btn::after {
  border: none;
}

.retake-btn {
  background: rgba(255,255,255,0.2);
  color: white;
  border: 2rpx solid rgba(255,255,255,0.5);
}

.confirm-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
  color: white;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}
